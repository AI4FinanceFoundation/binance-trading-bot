# Copy to .env and fill in. Never commit .env.

BINANCE_API_KEY=
BINANCE_SECRET=

# true = Binance testnet (get keys from https://testnet.binance.vision )
BINANCE_TESTNET=true

# Dry run: log signals, do not place orders
DRY_RUN=true

SYMBOL=BTC/USDT
TIMEFRAME=1h

# supertrend (default, widely used on retail charts) | ema_rsi
STRATEGY=supertrend
ST_ATR_PERIOD=10
ST_MULTIPLIER=3

EMA_FAST=12
EMA_SLOW=26
RSI_PERIOD=14
# Ignore buys if RSI(14) is above this (e.g. 70 = not buying overbought)
RSI_MAX_BUY=70

# Fraction of free quote balance (e.g. USDT) to use on each buy
QUOTE_INVEST_PCT=0.1

POLL_SEC=60
