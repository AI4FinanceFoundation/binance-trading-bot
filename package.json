{
  "name": "binance-trading-bot",
  "version": "1.0.0",
  "description": "TypeScript spot trading bot for Binance (SuperTrend default, EMA+RSI optional)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ccxt": "^4.4.80",
    "dotenv": "^16.4.5",
    "ioredis-om": "^5.10.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
